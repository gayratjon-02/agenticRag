# Copy to .env and adjust. Never commit .env.
# Host ports match docker-compose.yml (non-default to avoid clashing with local services).
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5440/rag
REDIS_URL=redis://localhost:6390/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Embeddings (local, via fastembed). Same model must be used for ingestion and query.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
# Chunking (deterministic, character-based)
CHUNK_SIZE=400
CHUNK_OVERLAP=80
# Retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.5
# Generation (Claude). Set ANTHROPIC_API_KEY to a real key to use the chat endpoint.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
# Hardening. Leave ADMIN_API_KEY empty for local dev (tenant creation open);
# set it in production to require X-Admin-Key on POST /tenants.
ADMIN_API_KEY=
RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
ENVIRONMENT=development
